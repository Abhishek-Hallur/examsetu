# ─────────────────────────────────────────────────────────────
# ExamSetu environment variables
# Copy to .env and fill in. Never commit .env.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Database (PostgreSQL). Use local Postgres, Supabase, Neon, or another provider.
DATABASE_URL=""

# Distributed rate limiting (Upstash Redis REST API)
# Required by src/lib/rate-limit.ts in deployed environments such as Vercel.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Authentication
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email / password reset
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="ExamSetu <noreply@examsetu.in>"

# Storage — Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# Payments — Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Ads — Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""