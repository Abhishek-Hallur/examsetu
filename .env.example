# ─────────────────────────────────────────────────────────────
# ExamSetu environment variables
# Copy to .env and fill in. Never commit .env.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Database (PostgreSQL). Use docker-compose, local Postgres, or Supabase.
DATABASE_URL=""

# Redis (caching / rate limiting)
REDIS_URL=""

# Auth — added in Phase 3
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email / OTP — added in Phase 3
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="ExamSetu <noreply@examsetu.in>"

# Storage — Cloudflare R2 (Phase 4/7)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# Payments — Razorpay (Phase 8)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Ads — Google AdSense (Phase 8)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""
